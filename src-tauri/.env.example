# Google OAuth 2.0 credentials for Google Drive API
# Copy this file to .env and fill in your values.
# Get these from: https://console.cloud.google.com/apis/credentials
#
# Option A – "Desktop app" credential (recommended, PKCE, no secret needed):
#   Set only GOOGLE_CLIENT_ID. Leave GOOGLE_CLIENT_SECRET unset or empty.
#
# Option B – "Web application" credential (requires a secret):
#   Set both GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET.
#   Also add http://127.0.0.1 (without a port) to "Authorized redirect URIs"
#   in the Google Cloud Console credentials page.

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret   # only needed for Web application credentials
