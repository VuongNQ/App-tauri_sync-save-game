# Google OAuth 2.0 credentials for Google Drive API
# Copy this file to .env and fill in your values.
# Get these from: https://console.cloud.google.com/apis/credentials
# → Click your Desktop app credential → Download JSON → copy client_id and client_secret
#
# NOTE: Desktop app credentials require client_secret for token exchange.
# It is "non-confidential" (safe to embed in app binary) but MUST be sent to Google.

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
